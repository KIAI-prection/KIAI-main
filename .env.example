# KIAI Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Only .env.example is committed.
#
# Setup steps:
#   1. cp .env.example .env
#   2. Fill in DATABASE_URL from Neon console
#   3. Fill in OPERATOR_SECRET with: openssl rand -hex 32
#   4. Fill in DEPLOYER_PRIVATE_KEY and SUI_OPERATOR_PRIVATE_KEY for contract ops

# ---------------------------------------------------------------------------
# Database — Neon (serverless PostgreSQL)
# ---------------------------------------------------------------------------
# Create a project at https://console.neon.tech (region: ap-southeast-1 for Japan)
# Use the POOLED connection string for Next.js API routes (serverless-compatible)
# Format: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/kiai?sslmode=require"

# ---------------------------------------------------------------------------
# Chain RPC endpoints (testnet)
# Rate-limited public endpoints — use dedicated nodes for production
# ---------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
SUI_TESTNET_RPC_URL="https://fullnode.testnet.sui.io:443"
# Sui GraphQL RPC for event indexing (NOT the same as the gRPC fullnode URL above)
# Source: https://docs.sui.io/develop/accessing-data/graphql/query-with-graphql
SUI_TESTNET_GRAPHQL_URL="https://graphql.testnet.sui.io/graphql"

# ---------------------------------------------------------------------------
# Collateral contract addresses (testnet — Circle official, verified 2026-06-02)
# Source: https://developers.circle.com/stablecoins/usdc-contract-addresses
# DO NOT change without re-verifying from Circle official docs
# ---------------------------------------------------------------------------
BASE_SEPOLIA_USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
SUI_TESTNET_USDC_TYPE="0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC"

# ---------------------------------------------------------------------------
# Deployed contract addresses — filled after Phase 4/5 deployment
# Full details in docs/DEPLOYMENTS.md
# ---------------------------------------------------------------------------

# Base Sepolia — KIAIVault.sol (custody vault, USDC collateral)
BASE_SEPOLIA_KIAI_VAULT_ADDRESS="0x3d1E1993fD3f30c64e884E5B777c7B4e55C458A8"

# Sui Testnet — kiai_vault Move package
SUI_TESTNET_KIAI_VAULT_PACKAGE_ID="0x1064637e3fb717e89b13de02b6c8babc9aa26a77bea9acdeb9d0cbf30ddaa089"

# Sui Testnet — KIAIVaultRegistry shared object (one per deployment)
SUI_TESTNET_KIAI_VAULT_REGISTRY_ID="0xa522ecb86041af442dddc00db3a24e107918443cc6d5fd486adc90bc65784754"

# Sui Testnet — OperatorCap object (held by the deployer address)
SUI_TESTNET_KIAI_OPERATOR_CAP_ID="0x583b904cc0837d44b16d6dd17df133938c8d0202a75c9d73358c9b3d9b393ace"

# Sui Testnet — Nagoya Basho 2026 Market<USDC> shared object
# One object ID per market — add more as markets are created on-chain
SUI_TESTNET_NAGOYA_MARKET_OBJECT_ID="0x09b7dccd64037e3c5fcef36dc43bd5f62fecfbe62f59a0431ec9c3b2a8205522"

# ---------------------------------------------------------------------------
# Deployer/operator wallets — testnet only, NEVER commit real values
# ---------------------------------------------------------------------------

# Base Sepolia deployer private key (hex, 0x-prefixed)
# Get testnet ETH: https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
DEPLOYER_PRIVATE_KEY=""

# Sui Testnet operator private key (suiprivkey1... format from: sui keytool export)
# Get testnet SUI: https://faucet.sui.io
SUI_OPERATOR_PRIVATE_KEY=""

# ---------------------------------------------------------------------------
# Indexer — Phase 6
# ---------------------------------------------------------------------------
# Phase 6 (testnet) uses custom viem + Sui GraphQL pollers — no external service needed.
# ENVIO_API_TOKEN is for the production mainnet upgrade to Envio HyperIndex (optional).
# Leave blank for Phase 6 testnet.
ENVIO_API_TOKEN=""

# ---------------------------------------------------------------------------
# Ops readiness — Phase 10
# ---------------------------------------------------------------------------
# ISO timestamp for the most recent source-pack refresh before beta changes.
# Refresh Base, Sui, Circle USDC, Tether USDT support, and indexer docs, then set this.
KIAI_SOURCE_REFRESHED_AT=""

# ---------------------------------------------------------------------------
# Operator auth — Phase 3
# ---------------------------------------------------------------------------
# Bearer token for KIAI admin API routes (/api/admin/*)
# Generate with: openssl rand -hex 32
OPERATOR_SECRET=""

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
