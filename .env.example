# KIAI Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Only .env.example is committed.
#
# Setup steps:
#   1. cp .env.example .env
#   2. Fill in DATABASE_URL from Neon console
#   3. Fill in OPERATOR_SECRET with: openssl rand -hex 32
#   4. Fill in DEPLOYER_PRIVATE_KEY and SUI_OPERATOR_PRIVATE_KEY for contract ops

# ---------------------------------------------------------------------------
# Database — Neon (serverless PostgreSQL)
# ---------------------------------------------------------------------------
# Create a project at https://console.neon.tech (region: ap-southeast-1 for Japan)
# Use the POOLED connection string for Next.js API routes (serverless-compatible)
# Format: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/kiai?sslmode=require"

# ---------------------------------------------------------------------------
# Chain RPC endpoints (mainnet)
# Rate-limited public endpoints — use dedicated nodes for production
# ---------------------------------------------------------------------------
BASE_MAINNET_RPC_URL="https://mainnet.base.org"
SUI_MAINNET_RPC_URL="https://fullnode.mainnet.sui.io:443"
# Sui GraphQL RPC for event indexing (NOT the same as the gRPC fullnode URL above)
# Source: https://docs.sui.io/develop/accessing-data/graphql/query-with-graphql
SUI_MAINNET_GRAPHQL_URL="https://graphql.mainnet.sui.io/graphql"

# ---------------------------------------------------------------------------
# Collateral contract addresses (mainnet — Circle official, verified 2026-06-19)
# Source: https://developers.circle.com/stablecoins/usdc-contract-addresses
# DO NOT change without re-verifying from Circle official docs
# ---------------------------------------------------------------------------
BASE_MAINNET_USDC_ADDRESS="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
SUI_MAINNET_USDC_TYPE="0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC"

# ---------------------------------------------------------------------------
# Deployed contract addresses — filled after mainnet deployment
# Full details in docs/DEPLOYMENTS.md
# ---------------------------------------------------------------------------

# Base Mainnet — KIAIVault.sol (custody vault, USDC collateral)
BASE_MAINNET_KIAI_VAULT_ADDRESS=""
BASE_MAINNET_DEPLOYMENT_BLOCK=""

# Sui Mainnet — kiai_vault Move package
SUI_MAINNET_KIAI_VAULT_PACKAGE_ID=""

# Sui Mainnet — KIAIVaultRegistry shared object (one per deployment)
SUI_MAINNET_KIAI_VAULT_REGISTRY_ID=""

# Sui Mainnet — OperatorCap object (held by the deployer address)
SUI_MAINNET_KIAI_OPERATOR_CAP_ID=""
SUI_MAINNET_DEPLOYMENT_CHECKPOINT=""

# ---------------------------------------------------------------------------
# Deployer/operator wallets — mainnet values, NEVER commit real values
# ---------------------------------------------------------------------------

# Base Mainnet deployer private key (hex, 0x-prefixed)
DEPLOYER_PRIVATE_KEY=""

# Sui Mainnet operator private key (suiprivkey1... format from: sui keytool export)
SUI_OPERATOR_PRIVATE_KEY=""

# ---------------------------------------------------------------------------
# Sports event source adapters — optional evidence prefill
# ---------------------------------------------------------------------------
# API-FOOTBALL fixture adapter. Used only by the authenticated operator route
# /api/admin/markets/:id/source-adapters/api-football.
# API data pre-fills evidence; it does not silently finalize markets.
API_FOOTBALL_API_KEY=""
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
SPORTS_DATA_API_KEY=""

# ---------------------------------------------------------------------------
# Resolution operations — optional local controls
# ---------------------------------------------------------------------------
# Set to true only for controlled tests that need to bypass the dispute window.
KIAI_ALLOW_EARLY_RESOLUTION_FINALIZE=""

# Override where raw evidence payload JSON artifacts are archived locally.
# Defaults to .kiai/evidence-archive when unset.
RESOLUTION_EVIDENCE_ARCHIVE_DIR=""

# ---------------------------------------------------------------------------
# Ops readiness — Phase 10
# ---------------------------------------------------------------------------
# ISO timestamp for the most recent source-pack refresh before beta changes.
# Refresh Base, Sui, Circle USDC, Tether USDT support, and indexer docs, then set this.
KIAI_SOURCE_REFRESHED_AT="2026-06-05T10:44:46.656Z"

# ---------------------------------------------------------------------------
# Operator auth — Phase 3
# ---------------------------------------------------------------------------
# Bearer token for KIAI admin API routes (/api/admin/*)
# Generate with: openssl rand -hex 32
OPERATOR_SECRET=""
