# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.*
.pnpm-store/

# Yarn Berry (if ever adopted)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Environment & secrets
# Never commit real credentials. Commit .env.example as the template instead.
# =============================================================================
.env
.env.*
!.env.example
!.env.template
!.env*.example

# =============================================================================
# Next.js
# =============================================================================
.next/
out/

# =============================================================================
# Build & cache
# =============================================================================
build/
dist/
.turbo/
.cache/

# =============================================================================
# Testing & coverage
# =============================================================================
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
blob-report/
playwright/.cache/

# =============================================================================
# Logs & debug
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Deployment
# =============================================================================
.vercel/

# =============================================================================
# Database (local dev)
# =============================================================================
*.db
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal

# =============================================================================
# IDE & editors
# =============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =============================================================================
# Certificates & keys
# =============================================================================
*.pem
*.key
*.p12
*.pfx

# =============================================================================
# Linting & formatting caches
# =============================================================================
.eslintcache
.prettiercache
.stylelintcache

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# MCP & local tooling (project-specific)
# =============================================================================
.playwright-mcp/
.firecrawl/
.gstack/

# =============================================================================
# Foundry (EVM contracts)
# Commit: src/, test/, script/, foundry.toml, foundry.lock, broadcast/
# Ignore: lib/ (reinstall via forge install), out/ (forge build), cache/
# =============================================================================
contracts/lib/
contracts/out/
contracts/cache/

# =============================================================================
# Sui / Move contracts
# Commit: sources/, tests/, Move.toml, Move.lock, Published.toml
# Ignore: build/ (sui move build), .move/ (local cache)
# Published.toml explicitly says "SHOULD be committed to source control"
# =============================================================================
contracts/sui/build/
contracts/sui/.move/

# =============================================================================
# Misc
# =============================================================================
*.tgz
*.tar.gz
.sentryclirc
